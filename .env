# Public routing
# This would be set to the production domain on deployment and is used by
# Traefik to route traffic and acquire TLS certificates.
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

# Environment: local, staging, production.
ENVIRONMENT=local

PROJECT_NAME="Bilibili Media Ingestion Service"
STACK_NAME=bili-media-ingestion-service

# Auth and operator bootstrap
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
# Production must replace these placeholders.
SECRET_KEY=changethis
MEDIA_SIGNING_SECRET=
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Email
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Object storage and media pipeline
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
S3_FORCE_PATH_STYLE=True
INGEST_TMP_DIR=/tmp/bili-ingest
# cpu, videotoolbox (macOS), or nvenc (NVIDIA ffmpeg builds).
FFMPEG_VIDEO_ACCELERATOR=cpu

# Bilibili authenticated access
BILIBILI_COOKIE_HEADER=
YT_DLP_COOKIES_FILE=
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_USER_AGENT=
YT_DLP_IMPERSONATE=chrome

# Operations and diagnostics
SELF_OWNED_OWNER_MIDS=
SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

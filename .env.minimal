# Minimal full-feature configuration example.
# Copy this file to `.env.local` or use it as a deployment checklist.
# Replace every value marked with `REPLACE_...` before running outside local tests.

# Public routing
ENVIRONMENT=production
PROJECT_NAME="Bilibili Media Ingestion Service"
STACK_NAME=bili-media-ingestion-service
FRONTEND_HOST=https://bili.example.com
BACKEND_PUBLIC_URL=https://api.example.com
BACKEND_CORS_ORIGINS=https://bili.example.com,https://api.example.com

# Frontend build-time API URL.
# Vite embeds this into static assets during `bun run build` / Docker build.
VITE_API_URL=https://api.example.com

# Auth and first superuser
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY
MEDIA_SIGNING_SECRET=REPLACE_WITH_RANDOM_MEDIA_SIGNING_SECRET
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# PostgreSQL external dependency
POSTGRES_SERVER=postgres.example.internal
POSTGRES_PORT=5432
POSTGRES_DB=bili_media
POSTGRES_USER=bili_media
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD

# S3-compatible object storage external dependency
S3_ENDPOINT_URL=https://s3.example.internal
S3_ACCESS_KEY=REPLACE_WITH_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_S3_SECRET_KEY
S3_BUCKET=bili-media
S3_REGION=
S3_FORCE_PATH_STYLE=true
S3_MULTIPART_CHUNK_SIZE_BYTES=8388608

# Ingestion temp files and media processing
INGEST_TMP_DIR=/tmp/bili-ingest
YT_DLP_BINARY=yt-dlp
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
# cpu, videotoolbox, or nvenc. nvenc also needs GPU runtime/device config.
FFMPEG_VIDEO_ACCELERATOR=cpu

# Bilibili authenticated access
# Recommended: save Netscape cookies.txt in the Admin -> Bilibili Access page.
# These variables are fallbacks for environments that prefer file/header config.
BILIBILI_COOKIE_HEADER=
YT_DLP_COOKIES_FILE=
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_USER_AGENT=
YT_DLP_IMPERSONATE=chrome

# Bilibili request pacing
BILIBILI_METADATA_TIMEOUT_SECONDS=10
BILIBILI_METADATA_RETRY_ATTEMPTS=3
BILIBILI_REQUEST_MIN_INTERVAL_SECONDS=0.8
BILIBILI_REQUEST_JITTER_SECONDS=0.4
BILIBILI_WBI_KEY_CACHE_TTL_SECONDS=600
BILIBILI_COMMENT_EMPTY_PAGE_RETRY_ATTEMPTS=3

# Worker polling and stale-claim recovery
METADATA_WORKER_POLL_INTERVAL_SECONDS=5
METADATA_WORKER_INTER_JOB_DELAY_SECONDS=300
DOWNLOAD_WORKER_POLL_INTERVAL_SECONDS=5
UPLOAD_WORKER_POLL_INTERVAL_SECONDS=5
PROCESSING_WORKER_POLL_INTERVAL_SECONDS=5
SUBTITLE_WORKER_POLL_INTERVAL_SECONDS=5
METADATA_WORKER_STALE_AFTER_SECONDS=900
DOWNLOAD_WORKER_STALE_AFTER_SECONDS=21600
UPLOAD_WORKER_STALE_AFTER_SECONDS=14400
PROCESSING_WORKER_STALE_AFTER_SECONDS=14400
SUBTITLE_WORKER_STALE_AFTER_SECONDS=14400

# Signed media access
SIGNED_URL_EXPIRE_SECONDS=900

# OpenAI subtitle transcription
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_TIMEOUT_SECONDS=300
OPENAI_TRANSCRIPTION_TEMPERATURE=0
SUBTITLE_TRANSCRIPTION_AUDIO_FORMAT=m4a
SUBTITLE_TRANSCRIPTION_AUDIO_BITRATE=48k
SUBTITLE_TRANSCRIPTION_AUDIO_COMPRESSION_LEVEL=5
SUBTITLE_TRANSCRIPTION_AUDIO_SAMPLE_RATE=16000
SUBTITLE_TRANSCRIPTION_MAX_UPLOAD_BYTES=26214400

# Email. Required for password recovery and test-email flows.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="Bilibili Media Ingestion Service"
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# Observability and diagnostics
SENTRY_DSN=
RUN_LIVE_S3_SMOKE=false

# Docker image names used by compose.
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest
